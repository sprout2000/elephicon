{
  "name": "elephicon",
  "productName": "Elephicon",
  "description": "Elephicon generates Apple ICNS and Microsoft ICO files from PNG files.",
  "version": "3.9.6",
  "license": "MIT",
  "author": {
    "name": "sprout2000"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:sprout2000/elephicon.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "rimraf dist && run-p dev:webpack dev:electron",
    "dev:webpack": "cross-env NODE_ENV=\"development\" webpack --progress",
    "dev:electron": "wait-on ./dist/index.html ./dist/main.js && electronmon .",
    "build": "rimraf dist && cross-env NODE_ENV=\"production\" webpack --progress",
    "lint": "biome check --write .",
    "publish": "ts-node scripts/builder.ts"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.4",
    "localforage": "^1.10.0",
    "mime-types": "^3.0.2",
    "png2icons": "^2.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typeface-roboto": "^1.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "wait-on": "^9.0.5",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
